# API
PORT=3001
NODE_ENV=development

# Database (docker-compose defaults)
DATABASE_URL="mysql://soccer:soccer@localhost:3306/soccer_predictions"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (Semana 2 — auth)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# API Football (Semana 3)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# CORS
WEB_ORIGIN=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Instagram OAuth (Meta — Instagram Login)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:3001/api/auth/instagram/callback
