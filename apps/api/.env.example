# API
PORT=3001
NODE_ENV=development

# Database (docker-compose defaults)
DATABASE_URL="mysql://soccer:soccer@localhost:3306/soccer_predictions?allowPublicKeyRetrieval=true"
# Prisma Migrate shadow DB — root pode CREATE DATABASE (docker-compose MYSQL_ROOT_PASSWORD)
SHADOW_DATABASE_URL="mysql://root:root@localhost:3306/prisma_shadow?allowPublicKeyRetrieval=true"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (Semana 2 — auth)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# football-data.org v4 (free: fixtures + scores + crests)
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# CORS / links de e-mail
WEB_ORIGIN=http://localhost:3000

# E-mail (Resend) — EMAIL_ENABLED=false apenas registra no log da API
EMAIL_ENABLED=false
RESEND_API_KEY=
MAIL_FROM="Soccer Predictions <onboarding@resend.dev>"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Instagram OAuth (Meta — Instagram Login)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:3001/api/auth/instagram/callback
