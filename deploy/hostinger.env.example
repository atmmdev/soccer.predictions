# Configure estas variáveis no hPanel (Node.js → Environment Variables)
# Domínio: https://soccer.atmm.dev

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_URL=https://soccer.atmm.dev

# --- API interna (proxy Next.js → NestJS) ---
API_INTERNAL_PORT=3001
API_INTERNAL_URL=http://127.0.0.1:3001

# --- Backend (apps/api) ---
NODE_ENV=production

# Opção A — URL única (use o host MySQL do hPanel se localhost falhar)
DATABASE_URL=mysql://USUARIO:SENHA@localhost:3306/NOME_DO_BANCO?allowPublicKeyRetrieval=true

# Opção B — variáveis separadas (útil para testar host remoto)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=USUARIO
# DB_PASSWORD=SENHA
# DB_NAME=NOME_DO_BANCO
#
# Se localhost falhar no Node.js app:
# 1. hPanel → Databases → Remote MySQL → marque "Any Host" (%) para o banco
# 2. Copie o hostname MySQL exibido nessa tela (ex.: srv123.hstgr.io)
# 3. Use em DATABASE_URL ou DB_HOST

JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria
JWT_EXPIRES_IN=7d

WEB_ORIGIN=https://soccer.atmm.dev

API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://soccer.atmm.dev/api/auth/google/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=https://soccer.atmm.dev/api/auth/instagram/callback
