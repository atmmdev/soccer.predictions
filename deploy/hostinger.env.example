# Configure estas variáveis no hPanel (Node.js → Environment Variables)
# Domínio: https://soccer.atmm.dev

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_URL=https://soccer.atmm.dev

# --- API interna (proxy Next.js → NestJS) ---
API_INTERNAL_PORT=3001
API_INTERNAL_URL=http://127.0.0.1:3001

# --- Backend (apps/api) ---
NODE_ENV=production

# Migrations: run from your PC with `npm run db:migrate` (runtime migrate is skipped in production)
SKIP_RUNTIME_MIGRATE=1

# NO SERVIDOR use localhost — srv*.hstgr.io só funciona fora (DBeaver)
DATABASE_URL=mysql://USUARIO:SENHA@localhost:3306/NOME_DO_BANCO?allowPublicKeyRetrieval=true

# Opção B — variáveis separadas
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=USUARIO
# DB_PASSWORD=SENHA
# DB_NAME=NOME_DO_BANCO
#
# srv*.hstgr.io funciona no DBeaver (fora do servidor), mas dentro do app Node.js
# no Hostinger o MySQL só responde em localhost. Use localhost na DATABASE_URL.

JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria
JWT_EXPIRES_IN=7d

WEB_ORIGIN=https://soccer.atmm.dev

# E-mail (Resend) — sem EMAIL_ENABLED=true a API só registra no log e não envia
EMAIL_ENABLED=true
RESEND_API_KEY=re_...
# Domínio verificado no Resend (onboarding@resend.dev só funciona para o e-mail da conta)
MAIL_FROM="Soccer Predictions <noreply@seu-dominio-verificado>"

FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://soccer.atmm.dev/api/auth/google/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=https://soccer.atmm.dev/api/auth/instagram/callback
